# ─────────────────────────────────────────────
#  TaskForge – Environment Variables Template
#  Copy this to .env and fill in your values.
#  On Render, set these as Environment Variables
#  in the dashboard (do NOT commit a real .env).
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=production

# JWT — use a long random string in production
JWT_SECRET=change_me_to_a_long_random_secret

# ── SQLite (default) ──────────────────────────
# For Render: set DB_PATH to a path on your Persistent Disk
# e.g. /var/data/taskforge.db
DB_CLIENT=sqlite3
DB_PATH=/var/data/taskforge.db

# ── MySQL (optional) ─────────────────────────
# Uncomment and fill these if switching to MySQL
# DB_CLIENT=mysql2
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASS=password
# DB_NAME=taskforge

# ── File Uploads ──────────────────────────────
# For Render: set to a path on your Persistent Disk
# e.g. /var/data/uploads
UPLOAD_DIR=/var/data/uploads
